# Copie para .env e preencha com seus dados.
# Na Hostinger: use os dados do MySQL que aparecem no hPanel (Bancos de dados MySQL).

APP_ENV=production
# URL base da aplicação (com barra no final). Ex.: https://www.aplicativoweb.com.br/pdv/
APP_URL=https://www.aplicativoweb.com.br/pdv/

DB_HOST=localhost
DB_NAME=u123456789_pdv
DB_USER=u123456789_user
DB_PASS=sua_senha_mysql

# Opcional: sessão
SESSION_SECURE=1
SESSION_SAMESITE=Lax

# Opcional: loja (relatórios / impressão)
STORE_NAME=Minha Loja
STORE_CNPJ=
STORE_ADDRESS=
STORE_PHONE=
